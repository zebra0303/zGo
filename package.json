{
  "name": "zgo-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server/index.js",
    "postinstall": "npm install --prefix client && npm install --prefix server",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "test": "npm run test --prefix client",
    "lint": "npm run lint --prefix client",
    "prepare": "husky"
  },
  "lint-staged": {
    "client/src/**/*.{ts,tsx}": [
      "npm run lint --prefix client",
      "npx prettier --write"
    ],
    "server/**/*.js": [
      "npx prettier --write"
    ],
    "*.{json,md}": [
      "npx prettier --write"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1"
  }
}
